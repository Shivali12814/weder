{
  "expo": {
    "name": "Weder",
    "slug": "weder",
    "scheme": "weder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#200406"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.weder.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#20040E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "70c259d4-3037-4b20-8dc2-00a10dab48e9"
      }
    },
    "owner": "shivalimaurya1221"
  }
}
